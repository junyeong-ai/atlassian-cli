# Atlassian API Configuration
# Choose one auth method explicitly: basic or service_account.

# Basic auth with Atlassian API token
ATLASSIAN_AUTH_METHOD=basic
ATLASSIAN_DOMAIN=your-domain.atlassian.net
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-api-token

# OAuth 2.0 service account
# ATLASSIAN_AUTH_METHOD=service_account
# ATLASSIAN_CLIENT_ID=your-client-id
# ATLASSIAN_CLIENT_SECRET=your-client-secret
# ATLASSIAN_CLOUD_ID=optional-cloud-id

# Jira Search Field Configuration (Optional)
# Priority hierarchy for field selection (highest to lowest):
# 1. API 'fields' parameter (per-request override)
# 2. JIRA_SEARCH_DEFAULT_FIELDS (completely replaces built-in defaults)
# 3. Built-in defaults + JIRA_SEARCH_CUSTOM_FIELDS (extends defaults)
# 4. Built-in defaults only (17 fields)

# Option 2: Override all default fields completely
# Comma-separated list of field names to return by default
# Example: Only return essential fields for minimal token usage
# JIRA_SEARCH_DEFAULT_FIELDS=key,summary,status,assignee,priority

# Option 3: Add custom fields to built-in defaults
# Comma-separated list of custom field IDs to add to the 17 built-in fields
# Example: Add sprint and story points custom fields
# JIRA_SEARCH_CUSTOM_FIELDS=customfield_10015,customfield_10016

# Built-in default fields (17): key, summary, status, priority, issuetype,
# assignee, reporter, creator, created, updated, duedate, resolutiondate,
# project, labels, components, parent, subtasks

# Response Optimization (Optional)
# Comma-separated JSON fields to remove from API responses
# RESPONSE_EXCLUDE_FIELDS=self,avatarUrls,iconUrl

# Confluence Field Configuration (Optional)
# Comma-separated list of additional includes for Confluence v2 API
# Valid values: ancestors, children, history, operations, labels, properties
# CONFLUENCE_CUSTOM_INCLUDES=ancestors,history

# Project/Space Filtering Configuration (Optional)
# Comma-separated list of Jira projects to filter by default
# JIRA_PROJECTS_FILTER=PROJ1,PROJ2

# Comma-separated list of Confluence spaces to filter by default
# CONFLUENCE_SPACES_FILTER=SPACE1,SPACE2

# Performance Configuration (Optional)
# REQUEST_TIMEOUT_MS=30000

# Logging: use -v, -vv, or -vvv CLI flags for info/debug/trace logs.
